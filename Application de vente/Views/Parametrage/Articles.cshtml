@model IEnumerable<ApplicationDeVente.Models.Article>
@{
    ViewData["Title"] = "Gestion des Articles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">📦 Gestion des Articles</h4>
        <small class="text-muted">Liste des articles avec leurs prix par période de contrat</small>
    </div>
    <div class="d-flex gap-2">
        <form id="importExcelForm" asp-action="ImporterArticles" method="post" enctype="multipart/form-data" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="file" id="fichierExcelInput" name="fichierExcel" accept=".xlsx,.csv" class="d-none" onchange="document.getElementById('importExcelForm').submit();" />
            <button type="button" class="btn btn-sm btn-success fw-bold" onclick="document.getElementById('fichierExcelInput').click();">
                📥 Importer Excel
            </button>
        </form>
        <a asp-action="CreerArticle" class="btn btn-primary fw-bold">
            ➕ Nouvel Article
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5 text-muted">
            <div style="font-size:3.5rem">📭</div>
            <h5 class="mt-3">Aucun article enregistré</h5>
            <p class="mb-3">Commencez par créer votre premier article de vente à bord.</p>
            <a asp-action="CreerArticle" class="btn btn-primary fw-bold">➕ Créer un Article</a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-header fw-bold" style="background:#d9230f; color:white;">
            📋 Liste des Articles (@Model.Count() articles)
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Nom de l'Article</th>
                        <th class="text-end">Prix Unitaire (EUR)</th>
                        <th>Valable Du</th>
                        <th>Au</th>
                        <th>Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var article in Model)
                    {
                        var today = DateTime.Today;
                        var actif = article.DateDebut <= today && article.DateFin >= today;
                        <tr>
                            <td><code>@article.CodeArticle</code></td>
                            <td>
                                <strong>@article.NomArticle</strong>
                                @if (!string.IsNullOrEmpty(article.Description))
                                {
                                    <br /><small class="text-muted">@article.Description</small>
                                }
                            </td>
                            <td class="text-end fw-bold text-primary">@article.PrixUnitaire.ToString("F2") €</td>
                            <td>@article.DateDebut.ToString("dd/MM/yyyy")</td>
                            <td>@article.DateFin.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (actif)
                                {
                                    <span class="badge bg-success">✅ Actif</span>
                                }
                                else if (article.DateDebut > today)
                                {
                                    <span class="badge bg-info text-dark">🕐 À venir</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">⏹ Expiré</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="ModifierArticle" asp-route-id="@article.Id"
                                   class="btn btn-sm btn-outline-primary">✏️ Modifier</a>
                                <form asp-action="SupprimerArticle" asp-route-id="@article.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Supprimer \'@article.NomArticle\' ?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">🗑️ Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
