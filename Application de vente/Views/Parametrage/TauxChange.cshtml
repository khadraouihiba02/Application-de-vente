@model IEnumerable<ApplicationDeVente.Models.TauxChange>
@{
    ViewData["Title"] = "Taux de Change EUR/TND";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">💱 Taux de Change EUR → TND</h4>
        <small class="text-muted">Définissez le taux de conversion par période. Le taux actif est celui dont la date couvre aujourd'hui.</small>
    </div>
    <a asp-action="CreerTaux" class="btn btn-primary fw-bold">
        ➕ Nouveau Taux
    </a>
</div>



@if (!Model.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5 text-muted">
            <div style="font-size:3.5rem">💱</div>
            <h5 class="mt-3">Aucun taux de change enregistré</h5>
            <p class="mb-3">Ajoutez votre premier taux EUR/TND pour commencer les conversions.</p>
            <a asp-action="CreerTaux" class="btn btn-primary fw-bold">➕ Ajouter un Taux</a>
        </div>
    </div>
}
else
{
    var tauxActif = Model.FirstOrDefault(t => t.DateDebut <= DateTime.Today && t.DateFin >= DateTime.Today);

    <div class="card shadow-sm border-0">
        <div class="card-header fw-bold" style="background:#d9230f; color:white;">
            📋 Liste des Taux de Change (@Model.Count() enregistrements)
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>De</th>
                        <th>Vers</th>
                        <th class="text-end">Taux</th>
                        <th>Valable Du</th>
                        <th>Au</th>
                        <th>Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        var today = DateTime.Today;
                        var actif = t.DateDebut <= today && t.DateFin >= today;
                        <tr>
                            <td><span class="badge bg-secondary fs-6">@t.DeviseSource</span></td>
                            <td><span class="badge bg-dark fs-6">@t.DeviseCible</span></td>
                            <td class="text-end fw-bold text-primary fs-6">@t.Taux.ToString("F4")</td>
                            <td>@t.DateDebut.ToString("dd/MM/yyyy")</td>
                            <td>@t.DateFin.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (actif)
                                {
                                    <span class="badge bg-success">✅ Actif</span>
                                }
                                else if (t.DateDebut > today)
                                {
                                    <span class="badge bg-info text-dark">🕐 À venir</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">⏹ Expiré</span>
                                }
                            </td>
                            <td class="text-center">
                                <form asp-action="SupprimerTaux" asp-route-id="@t.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Supprimer ce taux de change ?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">🗑️ Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (tauxActif != null)
    {
        <div class="alert alert-info mt-3">
            <strong>💡 Taux actif aujourd'hui :</strong>
            1 @tauxActif.DeviseSource = <strong>@tauxActif.Taux.ToString("F4") @tauxActif.DeviseCible</strong>
            &nbsp;|&nbsp; Valable du @tauxActif.DateDebut.ToString("dd/MM/yyyy") au @tauxActif.DateFin.ToString("dd/MM/yyyy")
        </div>
    }
    else
    {
        <div class="alert alert-warning mt-3">
            <strong>⚠️ Attention :</strong> Aucun taux de change n'est actif pour aujourd'hui.
        </div>
    }
}

