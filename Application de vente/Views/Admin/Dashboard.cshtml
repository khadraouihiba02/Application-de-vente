@{
    ViewData["Title"] = "Tableau de bord — Admin";
}

<div class="row g-4 mb-4">
    <div class="col-12">
        <h4 class="fw-bold text-dark mb-0">👑 Tableau de bord Administrateur</h4>
        <small class="text-muted">Vue globale du système VAB — Tunisair</small>
        <hr />
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100" style="border-left: 4px solid #d9230f !important; border-left-width: 4px;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="font-size:2.5rem;">👥</div>
                <div>
                    <div class="fw-bold fs-4">4</div>
                    <div class="text-muted small">Utilisateurs du système</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="font-size:2.5rem;">🟢</div>
                <div>
                    <div class="fw-bold fs-4">4</div>
                    <div class="text-muted small">Comptes actifs</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="font-size:2.5rem;">🔐</div>
                <div>
                    <div class="fw-bold fs-4">4</div>
                    <div class="text-muted small">Rôles définis</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="font-size:2.5rem;">🔴</div>
                <div>
                    <div class="fw-bold fs-4">0</div>
                    <div class="text-muted small">Comptes inactifs</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header fw-bold" style="background:#d9230f; color:white;">🔐 Rôles du Système</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Rôle</th>
                            <th>Responsabilité</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-dark">Admin</span></td>
                            <td>Gestion des utilisateurs</td>
                            <td><span class="badge bg-success">Actif</span></td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-primary">Agent</span></td>
                            <td>Saisie des états de ventes</td>
                            <td><span class="badge bg-success">Actif</span></td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-success">Catering</span></td>
                            <td>Contrôle et traitement des données</td>
                            <td><span class="badge bg-success">Actif</span></td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning text-dark">DCF</span></td>
                            <td>Validation et archivage</td>
                            <td><span class="badge bg-success">Actif</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header fw-bold" style="background:#373a3c; color:white;">⚡ Actions rapides</div>
            <div class="card-body d-grid gap-2">
                <a asp-controller="Admin" asp-action="GestionUsers" class="btn btn-primary fw-bold">
                    👥 Gérer les utilisateurs
                </a>
                <a href="#" class="btn btn-outline-secondary">
                    📊 Voir les statistiques globales
                </a>
            </div>
        </div>
    </div>
</div>
