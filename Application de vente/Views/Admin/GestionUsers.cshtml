@model IEnumerable<ApplicationDeVente.Models.UserWithRoleViewModel>
@{
    ViewData["Title"] = "Gestion des Utilisateurs";
}

<div class="row g-4 mb-4">
    <div class="col-12">
        <h4 class="fw-bold text-dark mb-0">👥 Gestion des Utilisateurs du Système</h4>
        <small class="text-muted">Créer, modifier et activer/désactiver les comptes utilisateurs</small>
        <hr />
    </div>
</div>

<div class="row g-4 mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <span class="badge bg-primary me-1">Agent</span>
            <span class="badge bg-success me-1">Catering</span>
            <span class="badge bg-warning text-dark me-1">DCF</span>
            <span class="badge bg-dark">Admin</span>
        </div>
        <a asp-action="CreerUser" class="btn btn-primary fw-bold">
            ➕ Ajouter un utilisateur
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header fw-bold" style="background:#d9230f; color:white;">
        📋 Liste des utilisateurs
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nom complet</th>
                    <th>Email</th>
                    <th>Rôle</th>
                    <th>Statut</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td><strong>@user.NomComplet</strong></td>
                        <td>@user.Email</td>
                        <td>
                            @switch (user.Role)
                            {
                                case "Admin":
                                    <span class="badge bg-dark">Admin</span>
                                    break;
                                case "Catering":
                                    <span class="badge bg-success">Catering</span>
                                    break;
                                case "DCF":
                                    <span class="badge bg-warning text-dark">DCF</span>
                                    break;
                                case "Agent":
                                    <span class="badge bg-primary">Agent</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@user.Role</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (user.Actif)
                            {
                                <span class="badge bg-success">✅ Actif</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">🔴 Désactivé</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="ModifierUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-1">✏️ Modifier</a>
                            
                            <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Voulez-vous modifier le statut de cet utilisateur ?')">
                                @Html.AntiForgeryToken()
                                @if (user.Actif)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-danger">🔴 Désactiver</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success">🟢 Activer</button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
