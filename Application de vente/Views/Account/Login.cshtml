@model ApplicationDeVente.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Connexion — VAB";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/simplex/bootstrap.min.css">
    <style>
            body {
                background: #f4f4f4;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            .login-wrapper {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem;
            }

            .login-card {
                width: 100%;
                max-width: 430px;
                border-top: 4px solid #d9230f;
                border-radius: 4px;
            }

            .brand-header {
                background: #d9230f;
                color: white;
                padding: 1.5rem 2rem;
                text-align: center;
            }

            .tunisair-logo {
                font-size: 2rem;
                font-weight: 900;
                letter-spacing: 2px;
            }

                .tunisair-logo span {
                    color: #ffc107;
                }

            footer {
                background: #373a3c;
                color: #aaa;
                text-align: center;
                padding: 0.75rem;
                font-size: 0.8rem;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-dark bg-dark px-3">
        <span class="navbar-brand fw-bold">
            <span style="color:#d9230f">✈</span> TUNISAIR — Système VAB
        </span>
        <span class="text-muted small">Ventes À Bord</span>
    </nav>

    <div class="login-wrapper">
        <div class="card login-card shadow">

            <div class="brand-header">
                <div class="tunisair-logo">TUN<span>IS</span>AIR</div>
                <h5 class="mt-2 mb-0">Système VAB</h5>
                <small style="opacity:.85">Gestion des Ventes À Bord</small>
            </div>

            <div class="card-body p-4">
                <h5 class="mb-4 text-center text-muted">Connexion</h5>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false)
                    </div>
                }

                @if (TempData["Erreur"] != null)
                {
                    <div class="alert alert-danger">
                        <strong>Erreur :</strong> @TempData["Erreur"]
                    </div>
                }

                <form asp-action="Login" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Adresse email</label>
                        <input asp-for="Email" class="form-control"
                               placeholder="exemple@tunisair.com.tn" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MotDePasse" class="form-label fw-semibold">Mot de passe</label>
                        <div class="input-group">
                            <input asp-for="MotDePasse" id="mdpInput" class="form-control"
                                   placeholder="••••••••" autocomplete="current-password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="toggleMdp()">👁</button>
                        </div>
                        <span asp-validation-for="MotDePasse" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="SeSouvenir" class="form-check-input" type="checkbox" />
                        <label asp-for="SeSouvenir" class="form-check-label text-muted">Se souvenir de moi</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold">Se connecter</button>
                </form>
            </div>

            <div class="card-footer text-center text-muted small bg-light py-2">
                Accès réservé au personnel autorisé TUNISAIR
            </div>
        </div>
    </div>

    <footer>
        © 2026 TUNISAIR — Système VAB &nbsp;|&nbsp; Direction Catering
    </footer>

    <script>
            function toggleMdp() {
                const f = document.getElementById('mdpInput');
                f.type = f.type === 'password' ? 'text' : 'password';
            }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

