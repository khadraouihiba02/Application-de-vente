@model ApplicationDeVente.Models.ViewModels.SaisieVentesViewModel
@{
    ViewData["Title"] = "Saisie des Ventes";
}

<!-- CDN pour Select2 -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<div class="row mb-3">
    <div class="col">
        <h4 class="fw-bold mb-0">📝 Nouvelle Saisie d'État de Ventes</h4>
        <small class="text-muted">Enregistrez les ventes par Feuille de Ligne (FL) sur un ou plusieurs vols.</small>
    </div>
</div>

<form asp-action="SaisirVentes" method="post" id="formSaisie">
    @Html.AntiForgeryToken()
    
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark">
            ✈️ En-tête de la Feuille de Ligne (FL)
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="NumeroFeuilleLigne" class="form-label fw-semibold"></label>
                    <input asp-for="NumeroFeuilleLigne" class="form-control" placeholder="ex: FL12345" style="text-transform: uppercase;" required />
                    <span asp-validation-for="NumeroFeuilleLigne" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DateVol" class="form-label fw-semibold"></label>
                    <input type="date" name="DateVol" id="DateVol" class="form-control" value="@Model.DateVol.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="DateVol" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="VolId" class="form-label fw-semibold">Vol</label>
                    <select asp-for="VolId" asp-items="Model.VolsDisponibles" class="form-select select2-vols" required data-placeholder="-- Sélectionner le vol --">
                        <option value="">-- Sélectionner le vol --</option>
                    </select>
                    <span asp-validation-for="VolId" class="text-danger small"></span>
                </div>
            </div>

            {{!-- Étape 2 : Équipage (Crews) du vol --}}
            <div class="row g-3 mt-2">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">👥 Équipage du Vol (Crews)</label>
                    <select name="CrewIds" id="CrewIds" class="form-select select2-crews" multiple="multiple" data-placeholder="-- Sélectionnez les PNC de l'équipage --">
                        @foreach (var pnc in Model.TousPNCs)
                        {
                            <option value="@pnc.Value">@pnc.Text</option>
                        }
                    </select>
                    <div class="form-text">Sélectionnez tous les PNC de l'équipage de ce vol.</div>
                </div>
                <div class="col-md-4">
                    <label asp-for="PNCVendeurId" class="form-label fw-semibold">🎯 PNC Vendeur</label>
                    <select asp-for="PNCVendeurId" class="form-select" id="PNCVendeurId" required>
                        <option value="">-- Sélectionnez d'abord les crews --</option>
                    </select>
                    <span asp-validation-for="PNCVendeurId" class="text-danger small"></span>
                    <div class="form-text text-primary">Choisissez le vendeur parmi l'équipage sélectionné.</div>
                </div>
            </div>
            
            <input type="hidden" asp-for="TauxChangeApplique" id="tauxApplique" value="@Model.TauxChangeApplique.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)" />
            <div class="alert alert-light border mt-3 mb-0 d-flex justify-content-between align-items-center p-2">
                <span class="small text-muted">💱 Taux de change appliqué : <strong class="text-dark">1 EUR = @Model.TauxChangeApplique.ToString("F4") TND</strong></span>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark d-flex justify-content-between align-items-center">
            <span>📦 Saisie des Articles</span>
            <button type="button" class="btn btn-sm btn-success fw-bold" id="btnAddLigne">+ Ajouter un article</button>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="articlesTable">
                <thead class="table-light">
                    <tr>
                        <th style="width: 30%;">Article (Code ou Désignation)</th>
                        <th class="text-center" style="width: 15%;">Prix Unit. (€)</th>
                        <th class="text-center" style="width: 10%;">Dotation</th>
                        <th class="text-center" style="width: 10%;">Complément</th>
                        <th class="text-center" style="width: 10%;">Vendues</th>
                        <th class="text-end" style="width: 15%;">Total (€)</th>
                        <th class="text-center" style="width: 10%;">Actions</th>
                    </tr>
                </thead>
                <tbody id="tbodyArticles">
                    <!-- Les lignes seront ajoutées dynamiquement ici -->
                </tbody>
            </table>
            <div id="emptyMessage" class="text-center text-muted p-4">
                <em>Aucun article saisi. Cliquez sur "+ Ajouter un article".</em>
            </div>
        </div>
    </div>

    <!-- Panneau de résumé des totaux et Encaissement -->
    <div class="row g-3 justify-content-end mb-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total Calculé (EUR) :</span>
                        <span class="fw-bold fs-5 text-primary" id="totalEur">0.00 €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                        <span class="text-muted">Total Calculé (TND) :</span>
                        <span class="fw-bold fs-5 text-secondary" id="totalTnd">0.000 TND</span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label asp-for="MontantEncaisseReel" class="form-label fw-bold text-dark mb-0"></label>
                        <div style="width: 150px;">
                            <input type="number" step="0.001" asp-for="MontantEncaisseReel" class="form-control text-end fw-bold text-success" id="montantEncaisse" required />
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Écart de caisse :</span>
                        <span class="fw-bold fs-6" id="ecartCaisse">0.000 TND</span>
                    </div>
                    <span asp-validation-for="MontantEncaisseReel" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Dashboard" class="btn btn-outline-secondary">Annuler</a>
        <button type="submit" class="btn btn-primary fw-bold px-4" id="btnSubmit">💾 Enregistrer la saisie</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initialisation Select2 pour les vols
            $('.select2-vols').select2({
                theme: "bootstrap-5",
                width: '100%'
            });

            // Initialisation Select2 pour les Crews (équipage)
            $('.select2-crews').select2({
                theme: "bootstrap-5",
                width: '100%',
                closeOnSelect: false,
                placeholder: "-- Sélectionnez les PNC de l'équipage --"
            });

            // Quand l'agent sélectionne/désélectionne des Crews,
            // la liste "PNC Vendeur" se met à jour automatiquement (sans AJAX)
            $('#CrewIds').on('change', function () {
                var selectedCrews = $(this).val(); // tableau des IDs sélectionnés
                var pncSelect = $('#PNCVendeurId');
                var currentVal = pncSelect.val(); // garder la valeur actuelle si possible
                
                pncSelect.empty();

                if (!selectedCrews || selectedCrews.length === 0) {
                    pncSelect.append('<option value="">-- Sélectionnez d\'abord les crews --</option>');
                    return;
                }

                pncSelect.append('<option value="">-- Choisir le PNC Vendeur --</option>');
                
                // Pour chaque crew sélectionné, on ajoute son option dans le menu Vendeur
                $('#CrewIds option:selected').each(function () {
                    var id = $(this).val();
                    var text = $(this).text();
                    pncSelect.append($('<option>', { value: id, text: text }));
                });

                // Remettre l'ancienne valeur si elle est encore dans la liste
                if (currentVal && pncSelect.find('option[value="' + currentVal + '"]').length > 0) {
                    pncSelect.val(currentVal);
                }
            });

            // ─── GESTION DYNAMIQUE DE LA GRILLE ARTICLES ───
            const taux = parseFloat($("#tauxApplique").val()) || 1.0;
            let indexLigne = 0;

            function recalculerTotaux() {
                let totalEur = 0;
                
                $("#tbodyArticles tr").each(function () {
                    const qteVendue = parseInt($(this).find(".val-vendue").val()) || 0;
                    const prixUnit = parseFloat($(this).find(".val-prix").val()) || 0.0;
                    
                    const totalLigne = qteVendue * prixUnit;
                    $(this).find(".val-total-ligne").text(totalLigne.toFixed(2) + " €");
                    
                    totalEur += totalLigne;
                });
                
                const totalTnd = totalEur * taux;
                $("#totalEur").text(totalEur.toFixed(2) + " €");
                $("#totalTnd").text(totalTnd.toFixed(3) + " TND");

                // Calcul de l'écart
                const encaisse = parseFloat($("#montantEncaisse").val()) || 0.0;
                const ecart = encaisse - totalTnd;
                
                const ecartSpan = $("#ecartCaisse");
                ecartSpan.text((ecart > 0 ? "+" : "") + ecart.toFixed(3) + " TND");
                
                if (ecart < 0) {
                    ecartSpan.removeClass("text-success").addClass("text-danger");
                } else {
                    ecartSpan.removeClass("text-danger").addClass("text-success");
                }

                // Cacher message vide
                if ($("#tbodyArticles tr").length > 0) {
                    $("#emptyMessage").hide();
                } else {
                    $("#emptyMessage").show();
                }
            }

            // Mettre à jour au changement d'encaissement
            $("#montantEncaisse").on("input", recalculerTotaux);

            // Ajouter une ligne
            $("#btnAddLigne").click(function () {
                const tr = `
                    <tr>
                        <td>
                            <input type="hidden" name="LignesArticles[${indexLigne}].ArticleId" class="val-id" value="0" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].CodeArticle" class="val-code" value="" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].Designation" class="val-desig" value="" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].PrixUnitaireEUR" class="val-prix" value="0" />
                            <select class="form-select select2-article" style="width: 100%;"></select>
                        </td>
                        <td class="text-center fw-bold text-primary display-prix">0.00 €</td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteDotation" class="form-control form-control-sm text-center" value="0" style="max-width: 80px; margin: 0 auto;" />
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteCompl" class="form-control form-control-sm text-center" value="0" style="max-width: 80px; margin: 0 auto;" />
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteVendue" class="form-control form-control-sm text-center fw-bold text-success val-vendue" value="0" style="max-width: 80px; margin: 0 auto;" required />
                        </td>
                        <td class="text-end fw-bold val-total-ligne" style="color: #2c3e50;">0.00 €</td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove" title="Supprimer">🗑️</button>
                        </td>
                    </tr>
                `;
                
                $("#tbodyArticles").append(tr);
                
                const nouvelleLigne = $("#tbodyArticles tr").last();
                const select = nouvelleLigne.find(".select2-article");

                // Initialiser Select2 AJAX
                select.select2({
                    theme: "bootstrap-5",
                    placeholder: "Taper code ou nom...",
                    minimumInputLength: 2,
                    ajax: {
                        url: '@Url.Action("RechercherArticle", "Agent")',
                        dataType: 'json',
                        delay: 250,
                        data: function (params) {
                            return { query: params.term };
                        },
                        processResults: function (data) {
                            return {
                                results: $.map(data, function (item) {
                                    return {
                                        id: item.id,
                                        text: item.code + " - " + item.designation,
                                        article: item
                                    }
                                })
                            };
                        }
                    }
                });

                // Quand on sélectionne un article
                select.on('select2:select', function (e) {
                    const data = e.params.data.article;
                    const row = $(this).closest("tr");
                    
                    row.find(".val-id").val(data.id);
                    row.find(".val-code").val(data.code);
                    row.find(".val-desig").val(data.designation);
                    // Remplacer virgule par point pour le format float
                    row.find(".val-prix").val(data.prix.toString().replace(',', '.'));
                    row.find(".display-prix").text(data.prix.toFixed(2) + " €");
                    
                    recalculerTotaux();
                    // Focus sur dotation
                    row.find("input[name*='QuantiteDotation']").focus();
                });

                // Écouter les changements sur la qté vendue
                nouvelleLigne.find(".val-vendue").on("input", recalculerTotaux);

                indexLigne++;
                recalculerTotaux();
            });

            // Supprimer une ligne
            $(document).on("click", ".btn-remove", function () {
                $(this).closest("tr").remove();
                recalculerTotaux();
            });

            // Validation finale avant submit
            $("#formSaisie").submit(function(e) {
                if ($("#tbodyArticles tr").length === 0) {
                    alert("Veuillez ajouter au moins un article vendu.");
                    e.preventDefault();
                    return false;
                }
                
                // S'assurer qu'aucun articleId n'est à 0
                let invalid = false;
                $(".val-id").each(function() {
                    if($(this).val() == "0" || $(this).val() == "") invalid = true;
                });
                
                if(invalid) {
                    alert("Veuillez sélectionner un article valide pour chaque ligne.");
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}
