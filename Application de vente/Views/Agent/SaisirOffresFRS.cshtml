@model ApplicationDeVente.Models.ViewModels.SaisieOffresFRSViewModel
@{
    ViewData["Title"] = "Saisie des Offres FRS";
}

<div class="row mb-3">
    <div class="col">
        <h4 class="fw-bold mb-0">🎁 Nouvelle Saisie d'État d'Offres FRS</h4>
        <small class="text-muted">Enregistrez les offres de catering déclarées par le fournisseur (FRS) en face d'un vol PNC.</small>
    </div>
</div>

<form asp-action="SaisirOffresFRS" method="post" id="formSaisie">
    @Html.AntiForgeryToken()
    
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark">
            📝 En-tête de l'État des Offres FRS
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="NumeroEtat" class="form-label fw-semibold">N° État FRS</label>
                    <input asp-for="NumeroEtat" class="form-control" placeholder="ex: O-FRS-12345" style="text-transform: uppercase;" required />
                    <span asp-validation-for="NumeroEtat" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DateReception" class="form-label fw-semibold">Date de Réception</label>
                    <input type="date" name="DateReception" id="DateReception" class="form-control" value="@Model.DateReception.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="DateReception" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EtatDesOffresId" class="form-label fw-semibold">État des Offres PNC Associé</label>
                    <select asp-for="EtatDesOffresId" asp-items="Model.EtatsPNCDisponibles" class="form-select" required>
                        <option value="">-- Sélectionner l'état des offres PNC --</option>
                    </select>
                    <span asp-validation-for="EtatDesOffresId" class="text-danger small"></span>
                    <div class="form-text text-muted">Sélectionnez la feuille d'offres PNC correspondante à contrôler.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark d-flex justify-content-between align-items-center">
            <span>🎁 Offres Catering FRS</span>
            <button type="button" class="btn btn-sm btn-success fw-bold" id="btnAddLigne">+ Ajouter un article</button>
        </div>
        <div class="table-responsive" style="overflow: visible;">
            <table class="table table-hover align-middle mb-0" id="articlesTable">
                <thead class="table-light">
                    <tr>
                        <th style="width: 35%;">Article (Code ou Désignation)</th>
                        <th class="text-center" style="width: 20%;">Dotation Initiale FRS</th>
                        <th class="text-center" style="width: 20%;">Qté Restante FRS</th>
                        <th class="text-center" style="width: 20%;">Qté Consommée FRS</th>
                        <th class="text-center" style="width: 5%;">Actions</th>
                    </tr>
                </thead>
                <tbody id="tbodyArticles">
                    <!-- Les lignes seront ajoutées dynamiquement ici -->
                </tbody>
            </table>
            <div id="emptyMessage" class="text-center text-muted p-4">
                <em>Aucun article saisi. Cliquez sur "+ Ajouter un article".</em>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Dashboard" class="btn btn-outline-secondary">Annuler</a>
        <button type="submit" class="btn btn-warning fw-bold px-4 text-dark" id="btnSubmit">💾 Enregistrer la saisie FRS</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {
            let indexLigne = 0;

            function recalculerTotaux() {
                $("#tbodyArticles tr").each(function () {
                    const dotation = parseInt($(this).find(".val-dotation").val()) || 0;
                    const restante = parseInt($(this).find(".val-restante").val()) || 0;
                    
                    let consommee = dotation - restante;
                    if (consommee < 0) consommee = 0;

                    $(this).find(".val-consommee").val(consommee);
                });

                // Cacher message vide
                if ($("#tbodyArticles tr").length > 0) {
                    $("#emptyMessage").hide();
                } else {
                    $("#emptyMessage").show();
                }
            }

            // Ajouter une ligne
            $("#btnAddLigne").click(function () {
                const tr = `
                    <tr>
                        <td>
                            <input type="hidden" name="LignesArticles[${indexLigne}].CodeArticle" class="val-code" value="" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].Designation" class="val-desig" value="" />
                            <div class="position-relative">
                                <input type="text" class="form-control article-search-input" placeholder="Taper code ou nom..." autocomplete="off" />
                                <div class="list-group position-absolute w-100 article-suggestions shadow-sm" style="z-index: 1050; display: none; max-height: 250px; overflow-y: auto;"></div>
                            </div>
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].DotationInitialeFRS" class="form-control form-control-sm text-center val-dotation" value="0" style="max-width: 120px; margin: 0 auto;" required />
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteRestanteFRS" class="form-control form-control-sm text-center val-restante" value="0" style="max-width: 120px; margin: 0 auto;" required />
                        </td>
                        <td class="text-center">
                            <input type="number" readonly name="LignesArticles[${indexLigne}].QuantiteConsommeeFRS" class="form-control form-control-sm text-center bg-light fw-bold val-consommee" value="0" style="max-width: 120px; margin: 0 auto;" />
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove" title="Supprimer">🗑️</button>
                        </td>
                    </tr>
                `;
                
                $("#tbodyArticles").append(tr);
                
                const nouvelleLigne = $("#tbodyArticles tr").last();
                const inputRecherche = nouvelleLigne.find(".article-search-input");
                const suggestions = nouvelleLigne.find(".article-suggestions");

                // Recherche AJAX quand on tape
                inputRecherche.on("input", function() {
                    const query = $(this).val();
                    if (query.length >= 2) {
                        $.ajax({
                            url: '@Url.Action("RechercherArticle", "Agent")',
                            dataType: 'json',
                            data: { query: query },
                            success: function(data) {
                                suggestions.empty();
                                if (data.length > 0) {
                                    data.forEach(function(item) {
                                        suggestions.append(`
                                            <a href="#" class="list-group-item list-group-item-action py-2 suggestion-item" 
                                               data-code="${item.code}" 
                                               data-desig="${item.designation}">
                                               <strong>${item.code}</strong> - ${item.designation}
                                            </a>
                                        `);
                                    });
                                    suggestions.show();
                                } else {
                                    suggestions.append('<div class="list-group-item text-muted">Aucun résultat</div>');
                                    suggestions.show();
                                }
                            }
                        });
                    } else {
                        suggestions.hide();
                    }
                });

                // Si l'utilisateur quitte le champ ou tape sur Entrée/Tab sans cliquer
                inputRecherche.on("change", function() {
                    const query = $(this).val();
                    const row = $(this).closest("tr");
                    
                    if (query.length < 2 || (row.find(".val-code").val() && query.includes(row.find(".val-code").val()))) {
                        return;
                    }

                    $.ajax({
                        url: '@Url.Action("RechercherArticle", "Agent")',
                        dataType: 'json',
                        data: { query: query },
                        success: function(data) {
                            if (data.length > 0) {
                                const item = data[0];
                                row.find(".val-code").val(item.code);
                                row.find(".val-desig").val(item.designation);
                                inputRecherche.val(item.code + " - " + item.designation);
                                suggestions.hide();
                                recalculerTotaux();
                            }
                        }
                    });
                });

                // Cacher les suggestions si on clique ailleurs
                $(document).on("click", function(e) {
                    if (!$(e.target).closest('.position-relative').length) {
                        $(".article-suggestions").hide();
                    }
                });

                // Sélection d'un article
                suggestions.on("click", ".suggestion-item", function(e) {
                    e.preventDefault();
                    const row = $(this).closest("tr");
                    const data = $(this).data();

                    row.find(".val-code").val(data.code);
                    row.find(".val-desig").val(data.desig);
                    
                    inputRecherche.val(data.code + " - " + data.desig);
                    suggestions.hide();
                    recalculerTotaux();
                    
                    row.find(".val-dotation").focus();
                });

                nouvelleLigne.find(".val-dotation").on("input", recalculerTotaux);
                nouvelleLigne.find(".val-restante").on("input", recalculerTotaux);

                indexLigne++;
                recalculerTotaux();
            });

            // Supprimer une ligne
            $(document).on("click", ".btn-remove", function () {
                $(this).closest("tr").remove();
                recalculerTotaux();
            });

            // Validation finale
            $("#formSaisie").submit(function(e) {
                if ($("#tbodyArticles tr").length === 0) {
                    alert("Veuillez ajouter au moins un article.");
                    e.preventDefault();
                    return false;
                }
                
                let invalid = false;
                $(".val-code").each(function() {
                    if($(this).val() == "") invalid = true;
                });
                
                if(invalid) {
                    alert("Veuillez sélectionner un article valide pour chaque ligne.");
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}
