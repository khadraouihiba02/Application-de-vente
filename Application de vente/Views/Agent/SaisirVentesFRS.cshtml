@model ApplicationDeVente.Models.ViewModels.SaisieVentesFRSViewModel
@{
    ViewData["Title"] = "Saisie des Ventes FRS";
}

<div class="row mb-3">
    <div class="col">
        <h4 class="fw-bold mb-0">📦 Nouvelle Saisie d'État de Ventes FRS</h4>
        <small class="text-muted">Enregistrez les ventes déclarées par le fournisseur (FRS) en face d'un vol PNC.</small>
    </div>
</div>

<form asp-action="SaisirVentesFRS" method="post" id="formSaisie">
    @Html.AntiForgeryToken()
    
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark">
            📝 En-tête de l'État des Ventes FRS
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="NumeroEtat" class="form-label fw-semibold">N° État FRS</label>
                    <input asp-for="NumeroEtat" class="form-control" placeholder="ex: E-FRS-12345" style="text-transform: uppercase;" required />
                    <span asp-validation-for="NumeroEtat" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DateReception" class="form-label fw-semibold">Date de Réception</label>
                    <input type="date" name="DateReception" id="DateReception" class="form-control" value="@Model.DateReception.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="DateReception" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EtatDesVentesId" class="form-label fw-semibold">État des Ventes PNC Associé</label>
                    <select asp-for="EtatDesVentesId" asp-items="Model.EtatsPNCDisponibles" class="form-select" required>
                        <option value="">-- Sélectionner l'état des ventes PNC --</option>
                    </select>
                    <span asp-validation-for="EtatDesVentesId" class="text-danger small"></span>
                    <div class="form-text text-muted">Sélectionnez la feuille de ligne PNC correspondante à contrôler.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark d-flex justify-content-between align-items-center">
            <span>📦 Articles Facturés FRS</span>
            <button type="button" class="btn btn-sm btn-success fw-bold" id="btnAddLigne">+ Ajouter un article</button>
        </div>
        <div class="table-responsive" style="overflow: visible;">
            <table class="table table-hover align-middle mb-0" id="articlesTable">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40%;">Article (Code ou Désignation)</th>
                        <th class="text-center" style="width: 20%;">Prix Unit. FRS (€)</th>
                        <th class="text-center" style="width: 20%;">Qté Vendue FRS</th>
                        <th class="text-end" style="width: 15%;">Total (€)</th>
                        <th class="text-center" style="width: 5%;">Actions</th>
                    </tr>
                </thead>
                <tbody id="tbodyArticles">
                    <!-- Les lignes seront ajoutées dynamiquement ici -->
                </tbody>
            </table>
            <div id="emptyMessage" class="text-center text-muted p-4">
                <em>Aucun article saisi. Cliquez sur "+ Ajouter un article".</em>
            </div>
        </div>
    </div>

    <!-- Panneau de résumé des totaux et Écart FRS -->
    <div class="row justify-content-end mb-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                        <span class="text-muted">Total FRS Calculé (EUR) :</span>
                        <span class="fw-bold fs-5 text-secondary" id="totalEur">0.00 €</span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-dark fw-bold">Montant Déclaré FRS (EUR) :</span>
                        <div style="width: 140px;">
                            <input type="number" step="0.01" asp-for="MontantFRS" class="form-control text-end fw-bold text-primary" id="montantFRS" required />
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Écart de contrôle FRS :</span>
                        <span class="fw-bold fs-6" id="ecartFRS">0.00 €</span>
                    </div>
                    <span asp-validation-for="MontantFRS" class="text-danger small mt-1 d-block text-end"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Dashboard" class="btn btn-outline-secondary">Annuler</a>
        <button type="submit" class="btn btn-primary fw-bold px-4" id="btnSubmit">💾 Enregistrer la saisie FRS</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {
            let indexLigne = 0;

            function recalculerTotaux() {
                let totalEur = 0;
                
                $("#tbodyArticles tr").each(function () {
                    const qte = parseInt($(this).find(".val-qte").val()) || 0;
                    const prix = parseFloat($(this).find(".val-prix").val()) || 0.0;
                    
                    const totalLigne = qte * prix;
                    $(this).find(".val-total-ligne").text(totalLigne.toFixed(2) + " €");
                    
                    totalEur += totalLigne;
                });
                
                $("#totalEur").text(totalEur.toFixed(2) + " €");

                // Calcul de l'écart FRS
                const montantDeclare = parseFloat($("#montantFRS").val()) || 0.0;
                const ecart = montantDeclare - totalEur;
                const ecartSpan = $("#ecartFRS");
                
                ecartSpan.text((ecart >= 0 ? "+" : "") + ecart.toFixed(2) + " €");
                
                if (ecart < 0) {
                    ecartSpan.removeClass("text-success text-muted").addClass("text-danger");
                } else if (ecart > 0) {
                    ecartSpan.removeClass("text-danger text-muted").addClass("text-success");
                } else {
                    ecartSpan.removeClass("text-danger text-success").addClass("text-muted");
                }

                // Cacher message vide
                if ($("#tbodyArticles tr").length > 0) {
                    $("#emptyMessage").hide();
                } else {
                    $("#emptyMessage").show();
                }
            }

            $("#montantFRS").on("input", recalculerTotaux);

            // Ajouter une ligne
            $("#btnAddLigne").click(function () {
                const tr = `
                    <tr>
                        <td>
                            <input type="hidden" name="LignesArticles[${indexLigne}].CodeArticle" class="val-code" value="" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].Designation" class="val-desig" value="" />
                            <div class="position-relative">
                                <input type="text" class="form-control article-search-input" placeholder="Taper code ou nom..." autocomplete="off" />
                                <div class="list-group position-absolute w-100 article-suggestions shadow-sm" style="z-index: 1050; display: none; max-height: 250px; overflow-y: auto;"></div>
                            </div>
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" step="0.01" name="LignesArticles[${indexLigne}].PrixUnitaireFRS" class="form-control form-control-sm text-center val-prix" value="0" style="max-width: 120px; margin: 0 auto;" required />
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteVendueFRS" class="form-control form-control-sm text-center fw-bold val-qte" value="0" style="max-width: 100px; margin: 0 auto;" required />
                        </td>
                        <td class="text-end fw-bold val-total-ligne" style="color: #2c3e50;">0.00 €</td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove" title="Supprimer">🗑️</button>
                        </td>
                    </tr>
                `;
                
                $("#tbodyArticles").append(tr);
                
                const nouvelleLigne = $("#tbodyArticles tr").last();
                const inputRecherche = nouvelleLigne.find(".article-search-input");
                const suggestions = nouvelleLigne.find(".article-suggestions");

                // Recherche AJAX quand on tape
                inputRecherche.on("input", function() {
                    const query = $(this).val();
                    if (query.length >= 2) {
                        $.ajax({
                            url: '@Url.Action("RechercherArticle", "Agent")',
                            dataType: 'json',
                            data: { query: query },
                            success: function(data) {
                                suggestions.empty();
                                if (data.length > 0) {
                                    data.forEach(function(item) {
                                        suggestions.append(`
                                            <a href="#" class="list-group-item list-group-item-action py-2 suggestion-item" 
                                               data-code="${item.code}" 
                                               data-desig="${item.designation}" 
                                               data-prix="${item.prix}">
                                               <strong>${item.code}</strong> - ${item.designation}
                                            </a>
                                        `);
                                    });
                                    suggestions.show();
                                } else {
                                    suggestions.append('<div class="list-group-item text-muted">Aucun résultat</div>');
                                    suggestions.show();
                                }
                            }
                        });
                    } else {
                        suggestions.hide();
                    }
                });

                // Si l'utilisateur quitte le champ ou tape sur Entrée/Tab sans cliquer
                inputRecherche.on("change", function() {
                    const query = $(this).val();
                    const row = $(this).closest("tr");
                    
                    if (query.length < 2 || (row.find(".val-code").val() && query.includes(row.find(".val-code").val()))) {
                        return;
                    }

                    $.ajax({
                        url: '@Url.Action("RechercherArticle", "Agent")',
                        dataType: 'json',
                        data: { query: query },
                        success: function(data) {
                            if (data.length > 0) {
                                const item = data[0];
                                row.find(".val-code").val(item.code);
                                row.find(".val-desig").val(item.designation);
                                row.find(".val-prix").val(item.prix.toString().replace(',', '.'));
                                inputRecherche.val(item.code + " - " + item.designation);
                                suggestions.hide();
                                recalculerTotaux();
                            }
                        }
                    });
                });

                // Cacher les suggestions si on clique ailleurs
                $(document).on("click", function(e) {
                    if (!$(e.target).closest('.position-relative').length) {
                        $(".article-suggestions").hide();
                    }
                });

                // Sélection d'un article
                suggestions.on("click", ".suggestion-item", function(e) {
                    e.preventDefault();
                    const row = $(this).closest("tr");
                    const data = $(this).data();

                    row.find(".val-code").val(data.code);
                    row.find(".val-desig").val(data.desig);
                    row.find(".val-prix").val(data.prix.toString().replace(',', '.'));
                    
                    inputRecherche.val(data.code + " - " + data.desig);
                    suggestions.hide();
                    recalculerTotaux();
                    
                    row.find(".val-prix").focus();
                });

                nouvelleLigne.find(".val-prix").on("input", recalculerTotaux);
                nouvelleLigne.find(".val-qte").on("input", recalculerTotaux);

                indexLigne++;
                recalculerTotaux();
            });

            // Supprimer une ligne
            $(document).on("click", ".btn-remove", function () {
                $(this).closest("tr").remove();
                recalculerTotaux();
            });

            // Validation finale
            $("#formSaisie").submit(function(e) {
                if ($("#tbodyArticles tr").length === 0) {
                    alert("Veuillez ajouter au moins un article vendu.");
                    e.preventDefault();
                    return false;
                }
                
                let invalid = false;
                $(".val-code").each(function() {
                    if($(this).val() == "") invalid = true;
                });
                
                if(invalid) {
                    alert("Veuillez sélectionner un article valide pour chaque ligne.");
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}
