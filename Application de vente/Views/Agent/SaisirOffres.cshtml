@model ApplicationDeVente.Models.ViewModels.SaisieOffresViewModel
@{
    ViewData["Title"] = "Saisie des Offres";
}

<!-- CDN pour Select2 -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<div class="row mb-3">
    <div class="col">
        <h4 class="fw-bold mb-0">🎁 Nouvelle Saisie d'État des Offres à bord</h4>
        <small class="text-muted">Enregistrez les articles offerts (gratuitement ou prix réduit) sur la rotation.</small>
    </div>
</div>

<form asp-action="SaisirOffres" method="post" id="formSaisie">
    @Html.AntiForgeryToken()
    
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark">
            ✈️ En-tête de la Feuille de Ligne (FL)
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="NumeroFeuilleLigne" class="form-label fw-semibold"></label>
                    <input asp-for="NumeroFeuilleLigne" class="form-control" placeholder="ex: FL12345" style="text-transform: uppercase;" required />
                    <span asp-validation-for="NumeroFeuilleLigne" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DateVol" class="form-label fw-semibold"></label>
                    <input type="date" name="DateVol" id="DateVol" class="form-control" value="@Model.DateVol.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="DateVol" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="VolId" class="form-label fw-semibold">Vol</label>
                    <select asp-for="VolId" asp-items="Model.VolsDisponibles" class="form-select select2-vols" required data-placeholder="-- Sélectionner le vol --">
                        <option value="">-- Sélectionner le vol --</option>
                    </select>
                    <span asp-validation-for="VolId" class="text-danger small"></span>
                </div>
            </div>
            
            <input type="hidden" asp-for="TauxChangeApplique" id="tauxApplique" value="@Model.TauxChangeApplique.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)" />
            <div class="alert alert-light border mt-3 mb-0 d-flex justify-content-between align-items-center p-2">
                <span class="small text-muted">💱 Taux de change appliqué : <strong class="text-dark">1 EUR = @Model.TauxChangeApplique.ToString("F4") TND</strong></span>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white bg-dark d-flex justify-content-between align-items-center">
            <span>🎁 Saisie des Offres</span>
            <button type="button" class="btn btn-sm btn-success fw-bold" id="btnAddLigne">+ Ajouter un article</button>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="articlesTable">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%;">Article (Code ou Désignation)</th>
                        <th class="text-center" style="width: 15%;">Prix Unit. Normal (€)</th>
                        <th class="text-center" style="width: 10%;">Dotation</th>
                        <th class="text-center" style="width: 10%;">Complément</th>
                        <th class="text-center" style="width: 10%;">Qté Offerte</th>
                        <th class="text-center" style="width: 15%;">Prix Promo (€)</th>
                        <th class="text-end" style="width: 10%;">Total (€)</th>
                        <th class="text-center" style="width: 5%;">Actions</th>
                    </tr>
                </thead>
                <tbody id="tbodyArticles">
                    <!-- Les lignes seront ajoutées dynamiquement ici -->
                </tbody>
            </table>
            <div id="emptyMessage" class="text-center text-muted p-4">
                <em>Aucun article offert. Cliquez sur "+ Ajouter un article".</em>
            </div>
        </div>
    </div>

    <!-- Panneau de résumé des totaux -->
    <div class="row g-3 justify-content-end mb-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total Valeur Offres (EUR) :</span>
                        <span class="fw-bold fs-5 text-warning" id="totalEur">0.00 €</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Équivalent (TND) :</span>
                        <span class="fw-bold fs-5 text-secondary" id="totalTnd">0.000 TND</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Dashboard" class="btn btn-outline-secondary">Annuler</a>
        <button type="submit" class="btn btn-warning fw-bold px-4" id="btnSubmit">💾 Enregistrer les offres</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initialisation de Select2 pour les vols
            $('.select2-vols').select2({
                theme: "bootstrap-5",
                width: '100%',
                closeOnSelect: false
            });

            // ─── GESTION DYNAMIQUE DE LA GRILLE ARTICLES ───
            const taux = parseFloat($("#tauxApplique").val()) || 1.0;
            let indexLigne = 0;

            function recalculerTotaux() {
                let totalEur = 0;
                
                $("#tbodyArticles tr").each(function () {
                    const qteOfferte = parseInt($(this).find(".val-offerte").val()) || 0;
                    const prixPromo = parseFloat($(this).find(".val-prix-promo").val()) || 0.0;
                    
                    const totalLigne = qteOfferte * prixPromo;
                    $(this).find(".val-total-ligne").text(totalLigne.toFixed(2) + " €");
                    
                    totalEur += totalLigne;
                });
                
                const totalTnd = totalEur * taux;
                $("#totalEur").text(totalEur.toFixed(2) + " €");
                $("#totalTnd").text(totalTnd.toFixed(3) + " TND");

                // Cacher message vide
                if ($("#tbodyArticles tr").length > 0) {
                    $("#emptyMessage").hide();
                } else {
                    $("#emptyMessage").show();
                }
            }

            // Ajouter une ligne
            $("#btnAddLigne").click(function () {
                const tr = `
                    <tr>
                        <td>
                            <input type="hidden" name="LignesArticles[${indexLigne}].ArticleId" class="val-id" value="0" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].CodeArticle" class="val-code" value="" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].Designation" class="val-desig" value="" />
                            <input type="hidden" name="LignesArticles[${indexLigne}].PrixCatalogueEUR" class="val-prix-catalogue" value="0" />
                            <select class="form-select select2-article" style="width: 100%;"></select>
                        </td>
                        <td class="text-center fw-bold text-muted display-prix-catalogue"><del>0.00 €</del></td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteDotation" class="form-control form-control-sm text-center" value="0" style="max-width: 80px; margin: 0 auto;" />
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteCompl" class="form-control form-control-sm text-center" value="0" style="max-width: 80px; margin: 0 auto;" />
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" name="LignesArticles[${indexLigne}].QuantiteOfferte" class="form-control form-control-sm text-center fw-bold text-warning val-offerte" value="0" style="max-width: 80px; margin: 0 auto;" required />
                        </td>
                        <td class="text-center">
                            <input type="number" min="0" step="0.01" name="LignesArticles[${indexLigne}].PrixUnitairePromoEUR" class="form-control form-control-sm text-center val-prix-promo" value="0" style="max-width: 100px; margin: 0 auto;" />
                        </td>
                        <td class="text-end fw-bold val-total-ligne" style="color: #2c3e50;">0.00 €</td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove" title="Supprimer">🗑️</button>
                        </td>
                    </tr>
                `;
                
                $("#tbodyArticles").append(tr);
                
                const nouvelleLigne = $("#tbodyArticles tr").last();
                const select = nouvelleLigne.find(".select2-article");

                // Initialiser Select2 AJAX
                select.select2({
                    theme: "bootstrap-5",
                    placeholder: "Taper code ou nom...",
                    minimumInputLength: 2,
                    ajax: {
                        url: '@Url.Action("RechercherArticle", "Agent")',
                        dataType: 'json',
                        delay: 250,
                        data: function (params) {
                            return { query: params.term };
                        },
                        processResults: function (data) {
                            return {
                                results: $.map(data, function (item) {
                                    return {
                                        id: item.id,
                                        text: item.code + " - " + item.designation,
                                        article: item
                                    }
                                })
                            };
                        }
                    }
                });

                // Quand on sélectionne un article
                select.on('select2:select', function (e) {
                    const data = e.params.data.article;
                    const row = $(this).closest("tr");
                    
                    row.find(".val-id").val(data.id);
                    row.find(".val-code").val(data.code);
                    row.find(".val-desig").val(data.designation);
                    // Prix normal
                    row.find(".val-prix-catalogue").val(data.prix.toString().replace(',', '.'));
                    row.find(".display-prix-catalogue").html('<del>' + data.prix.toFixed(2) + ' €</del>');
                    
                    recalculerTotaux();
                    row.find("input[name*='QuantiteDotation']").focus();
                });

                nouvelleLigne.find(".val-offerte").on("input", recalculerTotaux);
                nouvelleLigne.find(".val-prix-promo").on("input", recalculerTotaux);

                indexLigne++;
                recalculerTotaux();
            });

            // Supprimer une ligne
            $(document).on("click", ".btn-remove", function () {
                $(this).closest("tr").remove();
                recalculerTotaux();
            });

            // Validation finale
            $("#formSaisie").submit(function(e) {
                if ($("#tbodyArticles tr").length === 0) {
                    alert("Veuillez ajouter au moins un article offert.");
                    e.preventDefault();
                    return false;
                }
                
                let invalid = false;
                $(".val-id").each(function() {
                    if($(this).val() == "0" || $(this).val() == "") invalid = true;
                });
                
                if(invalid) {
                    alert("Veuillez sélectionner un article valide pour chaque ligne.");
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}
