@model ApplicationDeVente.Models.ViewModels.CommissionViewModel
@{
    ViewData["Title"] = "Commission PNC";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-coins text-warning me-2"></i>Commission PNC
        </h1>
    </div>

    <!-- Filtre Mois/Année -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Mois</label>
                    <select name="mois" class="form-select">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(Model.Mois == i ? "selected" : null)">
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Année</label>
                    <select name="annee" class="form-select">
                        @for (int i = DateTime.Today.Year - 2; i <= DateTime.Today.Year + 1; i++)
                        {
                            <option value="@i" selected="@(Model.Annee == i ? "selected" : null)">@i</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search me-1"></i> Filtrer
                    </button>
                    <button type="button" class="btn btn-outline-success ms-2" onclick="window.print()">
                        <i class="fas fa-file-export me-1"></i> Exporter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header py-3 bg-light">
            <h6 class="m-0 font-weight-bold text-primary">État Nominatif des Commissions - @Model.NomMois</h6>
        </div>
        <div class="card-body">
            @if (!Model.Commissions.Any())
            {
                <div class="alert alert-info">Aucune vente enregistrée pour ce mois.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Matricule</th>
                                <th>Nom & Prénom</th>
                                <th class="text-end">Total Encaissé (TND)</th>
                                <th class="text-end text-success">Commission (15%)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Commissions.OrderBy(c => c.NomComplet))
                            {
                                <tr>
                                    <td><strong>@item.Matricule</strong></td>
                                    <td>@item.NomComplet</td>
                                    <td class="text-end">@item.TotalEncaisse.ToString("F3") TND</td>
                                    <td class="text-end text-success fw-bold">@item.CommissionCalculee.ToString("F3") TND</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="2" class="text-end">TOTAL GÉNÉRAL :</td>
                                <td class="text-end">@Model.Commissions.Sum(c => c.TotalEncaisse).ToString("F3") TND</td>
                                <td class="text-end text-success fs-5">@Model.TotalCommission.ToString("F3") TND</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="mt-4 text-end d-print-none">
                    <button class="btn btn-success" type="button">
                        <i class="fas fa-paper-plane me-2"></i>Transmettre à la Direction Gestion Paie
                    </button>
                </div>
            }
        </div>
    </div>
</div>
