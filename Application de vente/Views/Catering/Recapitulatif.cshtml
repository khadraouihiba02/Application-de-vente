@model ApplicationDeVente.Models.ViewModels.RecapitulatifMensuelViewModel
@{
    ViewData["Title"] = "Récapitulatif mensuel — Direction Catering";

    var listeMois = new Dictionary<int, string>
    {
        { 1, "Janvier" }, { 2, "Février" }, { 3, "Mars" }, { 4, "Avril" },
        { 5, "Mai" }, { 6, "Juin" }, { 7, "Juillet" }, { 8, "Août" },
        { 9, "Septembre" }, { 10, "Octobre" }, { 11, "Novembre" }, { 12, "Décembre" }
    };
}

<style>
    @@media print {
        .no-print { display: none !important; }
        .sidebar, .topbar, footer { display: none !important; }
        .main-content { margin-left: 0 !important; padding: 0 !important; }
        .card { border: 1px solid #ddd !important; shadow: none !important; }
    }
</style>

<!-- En-tête + Filtres + Actions -->
<div class="d-flex justify-content-between align-items-center mb-4 no-print flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-0 text-dark">📊 Récapitulatif Mensuel — Catering</h4>
        <small class="text-muted">Synthèse mensuelle du Chiffre d'Affaires, des contrôles FRS et du calcul de la Redevance.</small>
    </div>

    <div class="d-flex gap-2 align-items-center">
        <!-- Formulaire Filtre Période -->
        <form method="get" asp-action="Recapitulatif" class="d-flex gap-2 align-items-center">
            <select name="mois" class="form-select form-select-sm fw-bold">
                @foreach (var m in listeMois)
                {
                    <option value="@m.Key" selected="@(Model.Mois == m.Key)">@m.Value</option>
                }
            </select>
            <select name="annee" class="form-select form-select-sm fw-bold">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                {
                    <option value="@y" selected="@(Model.Annee == y)">@y</option>
                }
            </select>
            <button type="submit" class="btn btn-sm btn-dark fw-bold px-3">🔍 Appliquer</button>
        </form>

        <a href="@Url.Action("ExporterRecapitulatifCSV", new { mois = Model.Mois, annee = Model.Annee })" class="btn btn-sm btn-success fw-bold text-white ms-2">
            📥 Exporter (CSV)
        </a>
        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary fw-bold">
            🖨️ Imprimer
        </button>
    </div>
</div>

<!-- En-tête pour l'impression uniquement -->
<div class="d-none d-print-block mb-4 text-center border-bottom pb-3">
    <h2>✈ TUNISAIR — Direction Catering</h2>
    <h4>Récapitulatif Mensuel d'Activité — @Model.NomMois</h4>
    <p class="text-muted small">Généré le @DateTime.Now.ToString("dd/MM/yyyy à HH:mm")</p>
</div>

<!-- ════════ KPI CARDS ════════ -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100" style="border-top: 4px solid #d9230f;">
            <div class="card-body p-3 text-center">
                <small class="text-muted text-uppercase fw-semibold">CA Total Ventes (EUR)</small>
                <div class="fw-bold fs-3 text-danger mt-1">@Model.TotalVentesEUR.ToString("N2") €</div>
                <small class="text-muted">Encaissement : <strong>@Model.TotalVentesTND.ToString("N3") TND</strong></small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100" style="border-top: 4px solid #0275d8;">
            <div class="card-body p-3 text-center">
                <small class="text-muted text-uppercase fw-semibold">CA Déclaré FRS (EUR)</small>
                <div class="fw-bold fs-3 text-primary mt-1">@Model.TotalFRSEUR.ToString("N2") €</div>
                <small class="text-muted">Écart global : 
                    <strong class="@(Model.TotalEcartEUR != 0 ? "text-danger" : "text-success")">
                        @(Model.TotalEcartEUR >= 0 ? "+" : "")@Model.TotalEcartEUR.ToString("N2") €
                    </strong>
                </small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100" style="border-top: 4px solid #9C27B0;">
            <div class="card-body p-3 text-center">
                <small class="text-muted text-uppercase fw-semibold">Redevance Retenue</small>
                <div class="fw-bold fs-3 text-purple mt-1" style="color: #8E24AA;">@Model.RedevanceRetenue.ToString("N2") €</div>
                <small class="text-muted truncate d-block" title="@Model.MethodeRetenueNom">@Model.MethodeRetenueNom</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100" style="border-top: 4px solid #4CAF50;">
            <div class="card-body p-3 text-center">
                <small class="text-muted text-uppercase fw-semibold">Statut Contrôles FRS</small>
                <div class="d-flex justify-content-center gap-2 mt-2">
                    <span class="badge bg-success" title="Conformes">✅ @Model.NombreControlesConformes</span>
                    <span class="badge bg-danger" title="Écarts">⚠️ @Model.NombreControlesEcarts</span>
                    <span class="badge bg-warning text-dark" title="En attente FRS">⏳ @Model.NombreEnAttenteFRS</span>
                </div>
                <small class="text-muted d-block mt-2">Sur @Model.NombreEtatsVentes états de ventes</small>
            </div>
        </div>
    </div>
</div>

<!-- ════════ SECTION CALCUL REDEVANCE MENSUELLE ════════ -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header fw-bold text-white bg-dark d-flex justify-content-between align-items-center">
        <span>⚖️ Calcul Réglementaire de la Redevance Mensuelle — @Model.NomMois</span>
        <span class="badge bg-light text-dark">Règle TUNISAIR</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <!-- Méthode 1 -->
            <div class="col-md-6">
                <div class="card h-100 @(Model.RedevanceRetenue == Model.RedevanceMethode1 && Model.RedevanceMethode1 > 0 ? "border-success bg-light-success" : "border-light")">
                    <div class="card-body text-center p-3">
                        <div class="text-muted small fw-bold text-uppercase">Méthode 1 — Minimum Garanti par Passager</div>
                        <div class="fs-4 fw-bold text-dark mt-2">@Model.RedevanceMethode1.ToString("N2") €</div>
                        <div class="small text-muted mt-1">
                            Formula : <code>@Model.TotalPassagersEstimes passagers × 1,10 €</code>
                        </div>
                        @if (Model.RedevanceRetenue == Model.RedevanceMethode1 && Model.RedevanceMethode1 > 0)
                        {
                            <span class="badge bg-success mt-2">⭐ Méthode retenue (Plus avantageuse)</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Méthode 2 -->
            <div class="col-md-6">
                <div class="card h-100 @(Model.RedevanceRetenue == Model.RedevanceMethode2 && Model.RedevanceMethode2 > 0 ? "border-success bg-light-success" : "border-light")">
                    <div class="card-body text-center p-3">
                        <div class="text-muted small fw-bold text-uppercase">Méthode 2 — Pourcentage du Chiffre d'Affaires</div>
                        <div class="fs-4 fw-bold text-dark mt-2">@Model.RedevanceMethode2.ToString("N2") €</div>
                        <div class="small text-muted mt-1">
                            Formula : <code>42% × @Model.TotalVentesEUR.ToString("N2") € (CA Réel)</code>
                        </div>
                        @if (Model.RedevanceRetenue == Model.RedevanceMethode2 && Model.RedevanceMethode2 > 0)
                        {
                            <span class="badge bg-success mt-2">⭐ Méthode retenue (Plus avantageuse)</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-info border mt-3 mb-0 d-flex justify-content-between align-items-center p-2 px-3">
            <span class="small">
                💡 <strong>Principe de retenue :</strong> Conformément au contrat Catering TUNISAIR, le montant retenu pour la redevance est le maximum entre la Méthode 1 et la Méthode 2.
            </span>
            <span class="fw-bold fs-5 text-primary ms-3">@Model.RedevanceRetenue.ToString("N2") €</span>
        </div>
    </div>
</div>

<!-- ════════ TABLEAU DÉTAILLÉ DES VENTES ════════ -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header fw-bold text-white" style="background:#d9230f;">
        📋 Détail des Ventes & Contrôles FRS (@Model.VentesDetails.Count états)
    </div>
    <div class="card-body p-0">
        @if (!Model.VentesDetails.Any())
        {
            <div class="text-center text-muted py-5">
                <div style="font-size:3rem;">📭</div>
                <p class="mt-2 mb-0">Aucun état de ventes trouvé pour la période <strong>@Model.NomMois</strong>.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>N° FL</th>
                            <th>Date Vol</th>
                            <th>Vol</th>
                            <th>PNC Vendeur</th>
                            <th class="text-end">CA PNC (€)</th>
                            <th class="text-end">Encaissé (TND)</th>
                            <th class="text-end">Montant FRS (€)</th>
                            <th class="text-end">Écart (€)</th>
                            <th class="text-center">Statut FRS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.VentesDetails)
                        {
                            <tr>
                                <td><span class="badge bg-dark fs-6">@item.NumeroFeuilleLigne</span></td>
                                <td>@item.DateVol.ToString("dd/MM/yyyy")</td>
                                <td><span class="fw-semibold">@(string.IsNullOrEmpty(item.VolInfo) ? "N/A" : item.VolInfo)</span></td>
                                <td>@item.PNCVendeurNom</td>
                                <td class="text-end fw-bold text-primary">@item.MontantEURPNC.ToString("F2") €</td>
                                <td class="text-end text-muted">@item.MontantEncaisseTND.ToString("F3") TND</td>
                                <td class="text-end">
                                    @(item.MontantEURFRS.HasValue ? $"{item.MontantEURFRS.Value:F2} €" : "—")
                                </td>
                                <td class="text-end fw-bold">
                                    @if (item.EcartEUR.HasValue)
                                    {
                                        <span class="@(item.EcartEUR.Value != 0 ? "text-danger" : "text-success")">
                                            @(item.EcartEUR.Value >= 0 ? "+" : "")@item.EcartEUR.Value.ToString("F2") €
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.StatutControle == "Conforme")
                                    {
                                        <span class="badge bg-success">✅ Conforme</span>
                                    }
                                    else if (item.StatutControle == "Écart")
                                    {
                                        <span class="badge bg-danger">⚠️ Écart</span>
                                    }
                                    else if (item.StatutControle == "En attente")
                                    {
                                        <span class="badge bg-warning text-dark">⏳ En attente</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">⛔ Non saisi</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td colspan="4">TOTAL MENSUEL</td>
                            <td class="text-end text-primary fs-6">@Model.TotalVentesEUR.ToString("F2") €</td>
                            <td class="text-end text-muted fs-6">@Model.TotalVentesTND.ToString("F3") TND</td>
                            <td class="text-end text-secondary fs-6">@Model.TotalFRSEUR.ToString("F2") €</td>
                            <td class="text-end fs-6 @(Model.TotalEcartEUR != 0 ? "text-danger" : "text-success")">
                                @(Model.TotalEcartEUR >= 0 ? "+" : "")@Model.TotalEcartEUR.ToString("F2") €
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

<!-- ════════ TABLEAU DÉTAILLÉ DES OFFRES ════════ -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header fw-bold text-white" style="background:#373a3c;">
        🎁 Récapitulatif des Offres à bord Catering (@Model.OffresDetails.Count états)
    </div>
    <div class="card-body p-0">
        @if (!Model.OffresDetails.Any())
        {
            <div class="text-center text-muted py-4">
                <div style="font-size:2.5rem;">🎁</div>
                <p class="mt-2 mb-0">Aucun état d'offres pour la période <strong>@Model.NomMois</strong>.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>N° FL</th>
                            <th>Date Vol</th>
                            <th>Vol</th>
                            <th class="text-center">Total Dotations (PNC)</th>
                            <th class="text-center">Total Consommé (PNC)</th>
                            <th class="text-center">Total Consommé (FRS)</th>
                            <th class="text-end">Valeur Totale (€)</th>
                            <th class="text-center">Statut FRS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OffresDetails)
                        {
                            <tr>
                                <td><span class="badge bg-dark">@item.NumeroFeuilleLigne</span></td>
                                <td>@item.DateVol.ToString("dd/MM/yyyy")</td>
                                <td><span class="fw-semibold">@(string.IsNullOrEmpty(item.VolInfo) ? "N/A" : item.VolInfo)</span></td>
                                <td class="text-center">@item.TotalDotationPNC</td>
                                <td class="text-center text-warning fw-bold">@item.TotalConsommePNC</td>
                                <td class="text-center text-primary fw-bold">@(item.StatutControle != "Non saisi" ? item.TotalConsommeFRS.ToString() : "—")</td>
                                <td class="text-end fw-bold text-warning">@item.ValeurTotaleEUR.ToString("F2") €</td>
                                <td class="text-center">
                                    @if (item.StatutControle == "Conforme")
                                    {
                                        <span class="badge bg-success">✅ Conforme</span>
                                    }
                                    else if (item.StatutControle == "Écart")
                                    {
                                        <span class="badge bg-danger">⚠️ Écart</span>
                                    }
                                    else if (item.StatutControle == "En attente")
                                    {
                                        <span class="badge bg-warning text-dark">⏳ En attente</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">⛔ Non saisi</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
