@model ApplicationDeVente.Models.ViewModels.VolViewModel
@{
    ViewData["Title"] = "Modifier Vol";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header fw-bold text-white" style="background:#d9230f;">
                ✏️ Modifier le Vol — @Model.NumeroVol
            </div>
            <div class="card-body p-4">
                <form asp-action="Modifier" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="NumeroVol" class="form-label fw-semibold"></label>
                            <input asp-for="NumeroVol" class="form-control" style="text-transform:uppercase;" />
                            <span asp-validation-for="NumeroVol" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Origine" class="form-label fw-semibold"></label>
                            <input asp-for="Origine" class="form-control" style="text-transform:uppercase;" maxlength="5" />
                            <span asp-validation-for="Origine" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Destination" class="form-label fw-semibold"></label>
                            <input asp-for="Destination" class="form-control" style="text-transform:uppercase;" maxlength="5" />
                            <span asp-validation-for="Destination" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch">
                                <input asp-for="Actif" class="form-check-input" type="checkbox" />
                                <label asp-for="Actif" class="form-check-label">Vol Actif</label>
                            </div>
                            
                            <div class="mt-3">
                                <label asp-for="SelectedPncIds" class="form-label fw-semibold"></label>
                                <select asp-for="SelectedPncIds" asp-items="Model.PncsDisponibles" class="form-select select2-pncs" multiple="multiple" data-placeholder="-- Sélectionner l'équipage --">
                                </select>
                                <span asp-validation-for="SelectedPncIds" class="text-danger small"></span>
                                <div class="form-text">Sélectionnez les agents PNC affectés à ce vol.</div>
                            </div>
                        </div>
                    </div>
                    <hr class="mt-4" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                        <button type="submit" class="btn btn-danger fw-bold">💾 Enregistrer les modifications</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.select2-pncs').select2({
                theme: "bootstrap-5",
                width: '100%',
                closeOnSelect: false
            });
        });
    </script>
}
