@model ApplicationDeVente.Models.ViewModels.ArchivageViewModel
@{
    ViewData["Title"] = "Archivage Documents";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-archive text-secondary me-2"></i>Archivage des Documents
        </h1>
    </div>

    <div class="card shadow">
        <div class="card-header py-3 bg-dark text-white d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold"><i class="fas fa-folder-open me-2"></i>Documents archivés</h6>
            <span class="badge bg-light text-dark rounded-pill">@Model.Documents.Count document(s)</span>
        </div>
        <div class="card-body">
            @if (!Model.Documents.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-folder-open fa-4x mb-3 opacity-25"></i>
                    <p class="fs-5">Aucun document archivé pour le moment.</p>
                    <small>Les documents apparaîtront ici une fois les redevances sauvegardées et les bordereaux clôturés.</small>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Type de Document</th>
                                <th>Période</th>
                                <th>Date d'Archivage</th>
                                <th>Archivé par</th>
                                <th class="text-center">Statut</th>
                                <th class="text-center d-print-none">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model.Documents)
                            {
                                <tr>
                                    <td>
                                        @if (doc.TypeDocument == "Redevance Mensuelle")
                                        {
                                            <span><i class="fas fa-file-invoice-dollar text-success me-2"></i>@doc.TypeDocument</span>
                                        }
                                        else if (doc.TypeDocument == "Bordereau de Règlement")
                                        {
                                            <span><i class="fas fa-file-invoice text-primary me-2"></i>@doc.TypeDocument</span>
                                        }
                                        else
                                        {
                                            <span><i class="fas fa-file text-secondary me-2"></i>@doc.TypeDocument</span>
                                        }
                                    </td>
                                    <td class="fw-bold">@doc.NomMois @doc.Annee</td>
                                    <td>@doc.DateArchivage.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge bg-light text-dark border">@doc.ArchivedBy</span></td>
                                    <td class="text-center">
                                        <span class="badge bg-success">
                                            <i class="fas fa-check me-1"></i>@doc.Statut
                                        </span>
                                    </td>
                                    <td class="text-center d-print-none">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
                                            <i class="fas fa-print me-1"></i> Imprimer
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
